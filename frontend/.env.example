# Шаблон переменных окружения для frontend.
# Скопировать в .env и подставить реальные значения. Файл .env не коммитить.
# При добавлении новых переменных — обновлять этот файл.

# Базовый URL API (со слэшем в конце).
# Пример: https://api.example.com/v1/ или http://localhost:3000/v1/
VITE_API_URL=http://localhost:3000/v1/

# Имя бота Telegram (без @). Используется для Telegram Login Widget в браузере.
# Legacy-виджет — без origin, домен привязывается через /setdomain в BotFather.
# Получить: создать бота у @BotFather, скопировать имя.
# Пример: EasyEnglishBot
VITE_TELEGRAM_BOT_NAME=

# Использовать реальную авторизацию через Telegram Login Widget в dev-режиме.
# По умолчанию false — на localhost используется мок-авторизация (кнопка "Dev: Войти").
# Установи true при использовании ngrok или реального домена для тестирования виджета.
# Примечание: виджет требует настроенный домен в @BotFather (/setdomain).
VITE_USE_REAL_AUTH=false
