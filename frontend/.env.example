# Шаблон переменных окружения для frontend.
# Скопировать в .env и подставить реальные значения. Файл .env не коммитить.
# При добавлении новых переменных — обновлять этот файл (см. docs/PRD.md, раздел 14).

# Базовый URL API (без слэша в конце). Пути запросов дополняются префиксом /v1.
# Пример: https://api.example.com или http://localhost:3000
VITE_API_URL=
