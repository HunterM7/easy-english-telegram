# Переменные окружения для docker-compose.
# Скопировать в .env и подставить реальные значения.

# Секрет для подписи JWT (обязательно сменить в production).
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Токен бота Telegram (от @BotFather).
TELEGRAM_BOT_TOKEN=

# URL фронтенда для CORS.
FRONTEND_URL=http://localhost:5173
