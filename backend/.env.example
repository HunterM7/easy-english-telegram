# Шаблон переменных окружения для backend.
# Скопировать в .env и подставить реальные значения. Файл .env не коммитить.
# При добавлении новых переменных — обновлять этот файл (см. docs/PRD.md, раздел 16).

# Секрет для подписи и верификации JWT. Должен быть длинной случайной строкой.
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Токен бота Telegram (от @BotFather). Нужен для проверки подписи initData от Mini App.
TELEGRAM_BOT_TOKEN=

# Строка подключения к PostgreSQL (например: postgresql://user:password@localhost:5432/easy_english).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/easy_english

# URL фронтенда для CORS (по умолчанию http://localhost:5173 для Vite).
FRONTEND_URL=http://localhost:5173

# Порт сервера (по умолчанию 3000).
PORT=3000

# Хост для привязки сервера.
# localhost — только локальные подключения (для разработки)
# 0.0.0.0 — все интерфейсы (для production/Docker/Railway)
HOST=0.0.0.0

# Swagger UI: http://localhost:3000/v1/docs (список эндпоинтов и схемы запросов)
